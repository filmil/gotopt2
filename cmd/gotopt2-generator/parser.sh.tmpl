#!/bin/bash
# Generated by gotopt2-generator

parse_args() {
{{- range .Flags }}
  {{- if eq .Type 4 }}
  {{ .ActualVarName }}__list=()
  {{- else }}
  {{ .ActualVarName }}={{ .DefaultValueQuoted }}
  {{- end }}
{{- end }}
  {{ .ArgsVarName }}=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help)
{{- if .Usage }}
        echo "{{ .Usage }}" >&2
{{- else }}
        echo "Usage:" >&2
{{- end }}
{{- range .Flags }}
        echo "  --{{ .Name }}" >&2
        echo {{ .HelpLineQuoted }} >&2
{{- end }}
        exit 11
        ;;
{{- range .Flags }}
  {{- if eq .Type 3 }}
      --{{ .Name }})
        {{ .ActualVarName }}={{ .TrueValueQuoted }}
        shift
        ;;
  {{- else if eq .Type 4 }}
      --{{ .Name }}=*)
        IFS=',' read -ra ADDR <<< "${1#*=}"
        for i in "${ADDR[@]}"; do
          {{ .ActualVarName }}__list+=("$i")
        done
        shift
        ;;
  {{- else }}
      --{{ .Name }}=*)
        {{ .ActualVarName }}="${1#*=}"
        shift
        ;;
  {{- end }}
{{- end }}
      --)
        shift
        while [[ $# -gt 0 ]]; do
          {{ .ArgsVarName }}+=("$1")
          shift
        done
        break
        ;;
      -*)
        echo "Unknown flag: $1" >&2
        return 1
        ;;
      *)
        {{ .ArgsVarName }}+=("$1")
        shift
        ;;
    esac
  done

}
